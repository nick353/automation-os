{
  "name": "automation-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "tsx watch apps/server/src/index.ts",
    "dev:web": "vite --host 127.0.0.1 apps/web",
    "start": "npm run start:server",
    "start:server": "AUTOMATION_OS_RESEARCH_PLAN_SCHEDULER_MS=${AUTOMATION_OS_RESEARCH_PLAN_SCHEDULER_MS:-0} AUTOMATION_OS_OBSIDIAN_PERIODIC_EXPORT_MS=${AUTOMATION_OS_OBSIDIAN_PERIODIC_EXPORT_MS:-0} node apps/server/dist/cli/processHygiene.js --cleanup --max-age-minutes 360 && AUTOMATION_OS_RESEARCH_PLAN_SCHEDULER_MS=${AUTOMATION_OS_RESEARCH_PLAN_SCHEDULER_MS:-0} AUTOMATION_OS_OBSIDIAN_PERIODIC_EXPORT_MS=${AUTOMATION_OS_OBSIDIAN_PERIODIC_EXPORT_MS:-0} node apps/server/dist/index.js",
    "process:scan": "npm run build:server && node apps/server/dist/cli/processHygiene.js --scan",
    "process:cleanup": "npm run build:server && node apps/server/dist/cli/processHygiene.js --cleanup",
    "qa:production": "node scripts/productionQa.mjs",
    "qa:production:replay": "node scripts/productionReplayQa.mjs",
    "qa:all-page-buttons": "node scripts/all_page_button_qa.mjs",
    "qa:production-operations-monitor": "node scripts/production_operations_monitor.mjs",
    "db:migrate:postgres": "node scripts/migrateSqliteToPostgres.mjs",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p apps/server/tsconfig.json && cp apps/server/src/db/schema.sql apps/server/dist/db/schema.sql && chmod +x apps/server/dist/browser/geminiVideoQaRunner.js",
    "build:web": "vite build apps/web",
    "import:codex": "npm run build:server && node apps/server/dist/cli/importCodex.js",
    "demo:daily-ai": "npm run build:server && node apps/server/dist/cli/demoDailyAi.js",
    "worker:once": "npm run build:server && node apps/server/dist/cli/workerOnce.js",
    "worker:loop": "npm run build:server && node apps/server/dist/cli/workerLoop.js",
    "worker:production-proof": "npm run build:server && node apps/server/dist/cli/workerProductionPickupProof.js",
    "worker:production-proof:stored": "npm run build:server && node apps/server/dist/cli/workerProductionFromStoredSecret.js --mode=proof",
    "worker:loop:stored": "npm run build:server && node apps/server/dist/cli/workerProductionFromStoredSecret.js --mode=loop",
    "local-history:triage": "npm run build:server && node apps/server/dist/cli/localHistoryTriage.js",
    "job:reconcile-completion": "npm run build:server && node apps/server/dist/cli/reconcileJobCompletion.js",
    "daily-ai:reconcile-blocker": "npm run build:server && node apps/server/dist/cli/reconcileDailyAiBlocker.js",
    "daily-ai:reconcile-completion": "npm run build:server && node apps/server/dist/cli/reconcileDailyAiCompletion.js",
    "nisenprints:reconcile-completion": "npm run build:server && node apps/server/dist/cli/reconcileNisenPrintsCompletion.js",
    "prompt-transfer:reconcile-blocker": "npm run build:server && node apps/server/dist/cli/reconcilePromptTransferBlocker.js",
    "automation:health": "node apps/server/dist/cli/automationHealth.js",
    "clean:dev-data": "npm run build:server && node apps/server/dist/cli/cleanDevData.js",
    "obsidian:export": "npm run build:server && node apps/server/dist/cli/exportObsidian.js",
    "obsidian:ingest": "npm run build:server && node apps/server/dist/cli/ingestObsidian.js",
    "project:audit": "npm run build:server && node apps/server/dist/cli/auditProjects.js",
    "project:register": "npm run build:server && node apps/server/dist/cli/registerProject.js",
    "obsidian:url-capture": "npm run build:server && node apps/server/dist/cli/captureUrl.js",
    "obsidian:x-auth-capture": "npm run build:server && node apps/server/dist/cli/captureXAuth.js",
    "obsidian:youtube-transcript-capture": "npm run build:server && node apps/server/dist/cli/captureYoutubeTranscript.js",
    "chrome:open:x-learning": "npm run build:server && node apps/server/dist/cli/openXLearningChrome.js",
    "chrome:health:x-learning": "npm run build:server && node apps/server/dist/cli/healthXLearningChrome.js",
    "chrome:open:youtube-transcript": "npm run build:server && node apps/server/dist/cli/openYoutubeTranscriptChrome.js",
    "chrome:health:youtube-transcript": "npm run build:server && node apps/server/dist/cli/healthYoutubeTranscriptChrome.js",
    "x-capture:review": "npm run build:server && node apps/server/dist/cli/xCaptureReview.js",
    "second-brain:process": "npm run build:server && node apps/server/dist/cli/secondBrainProcess.js",
    "typecheck:web": "tsc -p apps/web/tsconfig.json",
    "test": "npm run build:server && node --test --test-concurrency=1 apps/server/dist/tests/*.test.js"
  },
  "dependencies": {
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^5.0.0",
    "better-sqlite3": "^12.11.1",
    "express": "^4.19.2",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.468.0",
    "pg": "^8.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
