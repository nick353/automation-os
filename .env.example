# Automation OS local configuration template.
# Copy to .env for local use. Never commit real secrets or session tokens.

AUTOMATION_OS_PORT=8787
AUTOMATION_OS_DB=./data/automation-os.sqlite
AUTOMATION_OS_ARTIFACT_ROOT=./data/artifacts
AUTOMATION_OS_RESUME_CONTRACT_PATH=./data/resume-contract.json

# Preferred production database. If set, this overrides AUTOMATION_OS_DB and
# uses PostgreSQL instead of the local SQLite file.
# DATABASE_URL=postgresql://user:password@host:5432/database
# AUTOMATION_OS_DATABASE_URL=postgresql://user:password@host:5432/database

# Production safety. When PORT is present, Automation OS locks POST/PATCH/PUT/DELETE
# by default unless this token is configured and sent as x-automation-os-token.
# Set AUTOMATION_OS_REQUIRE_WRITE_TOKEN=0 only for a private, isolated service.
AUTOMATION_OS_REQUIRE_WRITE_TOKEN=1
# AUTOMATION_OS_WRITE_TOKEN=

# Optional local tool overrides.
AUTOMATION_OS_CODEX_BIN=codex
AUTOMATION_OS_NODE_BIN=node
AUTOMATION_OS_PLAYWRIGHT_CLI=/Users/nichikatanaka/.codex/skills/playwright/scripts/playwright_cli.sh

# Optional project runner overrides.
AUTOMATION_OS_DAILY_AI_PLAYWRIGHT_RUNNER=/Users/nichikatanaka/Documents/New project/scripts/run_daily_ai_playwright_cli.mjs
AUTOMATION_OS_SNS_MULTI_POSTER_RUNNER=/Users/nichikatanaka/Documents/Codex/automation-os/scripts/run_sns_multi_poster_ukiyoe_playwright_cli.mjs
AUTOMATION_OS_PROMPT_TRANSFER_UKIYOE_RUNNER=/Users/nichikatanaka/Documents/New project/scripts/prompt_transfer_ukiyoe.py
AUTOMATION_OS_NISENPRINTS_PLAYWRIGHT_RUNNER=/Users/nichikatanaka/Documents/Etsy/scripts/nisenprints_daily_product_runner.py

# Browser lanes are intentionally explicit.
SNS_MULTI_POSTER_CDP_PORT=9339
SNS_MULTI_POSTER_PROFILE_DIR=/Users/nichikatanaka/.sns-multi-poster-ukiyoe-playwright-chrome

# Secrets belong in the local secret store or your shell, never in Git.
# Create chat planner. "auto" uses local Codex CLI on local Mac runs, and local
# fallback in production-like hosts. Set "openai" only when API billing is OK.
# AUTOMATION_OS_CREATE_PLANNER_PROVIDER=auto
# AUTOMATION_OS_CODEX_PLANNER_BIN=codex
# AUTOMATION_OS_CODEX_PLANNER_TIMEOUT_MS=25000
# OPENAI_API_KEY=
# OPENAI_PLANNER_MODEL=gpt-4o-mini
# PRINTIFY_API_KEY=
# RUNWAY_API_KEY=
